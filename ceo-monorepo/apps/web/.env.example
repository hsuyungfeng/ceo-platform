# ============================================
# 環境變數配置 - CEO 團購平台
# ============================================

# 資料庫配置
DATABASE_URL="postgresql://username:password@localhost:5432/ceo_platform?schema=public"

# NextAuth 配置
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key-here"

# 電子郵件服務配置
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your-email@gmail.com"
EMAIL_SERVER_PASSWORD="your-email-password"
EMAIL_FROM="CEO團購平台 <noreply@ceo-buy.com>"

# Twilio SMS 服務配置
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"
SMS_ENABLED="true"

# 檔案上傳配置
UPLOAD_MAX_SIZE="10485760" # 10MB
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/gif,application/pdf"

# Redis 配置（快取和會話）
REDIS_URL="redis://localhost:6379"

# 應用程式配置
APP_NAME="CEO團購平台"
APP_URL="http://localhost:3000"
APP_ENV="development"

# 安全配置
JWT_SECRET="your-jwt-secret-key"
ENCRYPTION_KEY="your-encryption-key"

# API 金鑰
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
STRIPE_SECRET_KEY="your-stripe-secret-key"
STRIPE_PUBLISHABLE_KEY="your-stripe-publishable-key"

# 日誌配置
LOG_LEVEL="info"
LOG_FILE="logs/app.log"

# 效能配置
CACHE_TTL="3600" # 1小時
RATE_LIMIT_WINDOW="900000" # 15分鐘
RATE_LIMIT_MAX="100" # 每15分鐘100次請求

# 開發配置
DEBUG="true"
NODE_ENV="development"

# 測試配置
TEST_DATABASE_URL="postgresql://username:password@localhost:5432/ceo_platform_test?schema=public"

# ============================================
# 注意事項：
# 1. 將此文件複製為 .env.local 進行本地開發
# 2. 將此文件複製為 .env.production 進行生產部署
# 3. 確保敏感資訊（密碼、API金鑰）不被提交到版本控制
# 4. 生產環境應使用環境變數而非文件
# ============================================