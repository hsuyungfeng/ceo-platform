{
  "name": "CEO 團購平台",
  "short_name": "CEO團購",
  "description": "專業的醫療機構團購平台",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#2563eb",
  "orientation": "portrait-primary",
  "icons": [
    {
      "src": "/favicon.ico",
      "sizes": "64x64 32x32 24x24 16x16",
      "type": "image/x-icon"
    },
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshot-desktop.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "CEO 團購平台桌面版"
    },
    {
      "src": "/screenshot-mobile.png",
      "sizes": "750x1334",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "CEO 團購平台行動版"
    }
  ],
  "categories": ["business", "shopping", "productivity"],
  "shortcuts": [
    {
      "name": "查看通知",
      "short_name": "通知",
      "description": "查看所有通知",
      "url": "/notifications",
      "icons": [{ "src": "/icon-notification.png", "sizes": "96x96" }]
    },
    {
      "name": "商品目錄",
      "short_name": "商品",
      "description": "瀏覽商品目錄",
      "url": "/products",
      "icons": [{ "src": "/icon-products.png", "sizes": "96x96" }]
    },
    {
      "name": "供應商申請",
      "short_name": "供應商",
      "description": "提交供應商申請",
      "url": "/suppliers/register",
      "icons": [{ "src": "/icon-supplier.png", "sizes": "96x96" }]
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+ceo",
      "url": "/?protocol=%s"
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "scope": "/",
  "dir": "ltr",
  "lang": "zh-TW",
  "permissions": [
    "notifications",
    "background-sync",
    "periodic-background-sync"
  ],
  "display_override": ["window-controls-overlay", "standalone"],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "file_handlers": [],
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": ["image/*", ".pdf", ".doc", ".docx"]
        }
      ]
    }
  }
}